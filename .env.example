# ============================================
# Global Environment Variables
# ============================================

# Project
PROJECT_NAME=accommodation-discovery
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:27017/accommodation_db
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key

# Services (internal Docker network)
CORE_SERVICE_URL=http://core-service:3001
AI_SERVICE_URL=http://ai-service:8000
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8001

# API Gateway
GATEWAY_PORT=80
