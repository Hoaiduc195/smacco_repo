# ============================================
# Monolith — Environment Variables Template
# ============================================

# App
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/accommodation_db?schema=public

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=

# Groq LLM
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_TIMEOUT=20
GROQ_STREAMING_ENABLED=true

# Google Maps (optional)
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_LANGUAGE=vi
GOOGLE_MAPS_REGION=vn
