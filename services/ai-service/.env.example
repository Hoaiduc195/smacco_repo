# AI Service
PORT=8000
ENVIRONMENT=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/accommodation_db?schema=public

# Recommendation Service
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8001


# Groq API
GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b # default
# GROQ_TIMEOUT=20
GROQ_STREAMING_ENABLED=true