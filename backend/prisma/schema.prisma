generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [vector]
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  firebaseUid  String   @unique @map("firebase_uid")
  email        String?  @db.Text
  displayName  String?  @map("display_name") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  reviews       Review[]
  files         File[]
  chunks        Chunk[]
  conversations Conversation[]
  questions     Question[]
  answers       Answer[]
  answerVotes   AnswerVote[]
  presences     Presence[]

  @@map("app_users")
  @@index([firebaseUid], map: "idx_app_users_firebase_uid")
}

model Place {
  id           String   @id @default(uuid()) @db.Uuid
  source       String   @db.Text
  sourcePlaceId String? @map("source_place_id") @db.Text
  placeName    String   @map("place_name") @db.Text
  placeAddress String?  @map("place_address") @db.Text
  categories   String[]
  lat          Float
  lng          Float
  priceLevel    Int?     @map("price_level")
  coverImageUrl String?  @map("cover_image_url") @db.Text
  averageRating Float?   @map("average_rating")
  reviewCount   Int      @default(0) @map("review_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  reviews       Review[]
  files         File[]
  chunks        Chunk[]
  conversations Conversation[]
  questions     Question[]
  presences     Presence[]

  @@map("places")
  @@index([lat, lng], map: "idx_places_location")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  placeId    String   @map("place_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  rating     Int
  reviewText String?  @map("review_text") @db.Text
  source     String   @default("user") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  place Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("reviews")
  @@index([placeId], map: "idx_reviews_place_id")
}

model Question {
  id           String   @id @default(uuid()) @db.Uuid
  placeId      String   @map("place_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  title        String?  @map("title") @db.Text
  questionText String   @map("question_text") @db.Text
  status       String   @default("open") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  place Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers Answer[]

  @@map("questions")
  @@index([placeId], map: "idx_questions_place_id")
}

model Answer {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  answerText String   @map("answer_text") @db.Text
  upvotes    Int      @default(0) @map("upvotes")
  downvotes  Int      @default(0) @map("downvotes")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  votes    AnswerVote[]

  @@map("answers")
  @@index([questionId], map: "idx_answers_question_id")
}

model AnswerVote {
  id       String   @id @default(uuid()) @db.Uuid
  answerId String   @map("answer_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  vote     Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("answer_votes")
  @@unique([answerId, userId], map: "uq_answer_votes_answer_id_user_id")
  @@index([answerId], map: "idx_answer_votes_answer_id")
  @@index([userId], map: "idx_answer_votes_user_id")
}

model File {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  placeId    String   @map("place_id") @db.Uuid
  fileName   String?  @map("file_name") @db.Text
  mimeType   String?  @map("mime_type") @db.Text
  fileSize   Int?     @map("file_size")
  storageUrl String?  @map("storage_url") @db.Text
  fileStatus String   @map("file_status") @db.Text
  errorMessage String? @map("error_message") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

  place Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("files")
  @@index([placeId], map: "idx_files_place_id")
  @@index([fileStatus], map: "idx_files_status")
}

model Chunk {
  id         String   @id @default(uuid()) @db.Uuid
  placeId    String   @map("place_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  sourceType String   @map("source_type") @db.Text
  sourceId   String   @map("source_id") @db.Uuid
  chunkIndex Int?     @map("chunk_index")
  content    String   @db.Text
  tokenCount Int?     @map("token_count")
  metadata   Json?
  embedding  Unsupported("vector")
  createdAt  DateTime @default(now()) @map("created_at")

  place Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("chunks")
  @@index([placeId], map: "idx_chunks_place_id")
  @@index([sourceType], map: "idx_chunks_source_type")
  @@index([sourceId], map: "idx_chunks_source_id")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages Message[]
  placeReferences ConversationPlaceReference[]

  @@map("conversations")
}

model ConversationPlaceReference {
  id              String   @id @default(uuid()) @db.Uuid
  conversationId  String   @map("conversation_id") @db.Uuid
  placeId         String   @map("place_id") @db.Uuid

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  place         Place        @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@map("conversation_place_references")
  @@index([conversationId], map: "idx_cpr_conversation_id")
  @@index([placeId], map: "idx_cpr_place_id")
  @@unique([conversationId, placeId], map: "uq_cpr_conversation_place")

model Message {
  id               String   @id @default(uuid()) @db.Uuid
  conversationId   String   @map("conversation_id") @db.Uuid
  senderRole       String   @map("sender_role") @db.Text
  messageText      String   @map("message_text") @db.Text
  retrievedChunkIds String[] @map("retrieved_chunk_ids") @db.Uuid
  tokenInput       Int?     @map("token_input")
  tokenOutput      Int?     @map("token_output")
  latencyMs        Int?     @map("latency_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
  @@index([conversationId], map: "idx_messages_conversation_id")
}

model Presence {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  placeId   String   @map("place_id") @db.Uuid
  joinedAt  DateTime @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@map("presences")
  @@index([placeId], map: "idx_presences_place_id")
  @@index([userId], map: "idx_presences_user_id")
}
