# App
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/accommodation_db?schema=public

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=

# Groq API
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TIMEOUT=20
GROQ_STREAMING_ENABLED=true

# External APIs
GOONG_API_KEY=your_goong_api_key_here