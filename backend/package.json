{
  "name": "accommodation-discovery-monolith",
  "version": "1.0.0",
  "description": "Modular monolith for Accommodation Discovery Platform",
  "private": true,
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo",
    "build": "npm run clean && nest build",
    "postinstall": "prisma generate",
    "start": "npm run clean && nest start --watch",
    "start:dev": "npm run clean && nest start --watch",
    "start:debug": "npm run clean && nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.3.38",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "7.6.0",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "firebase-admin": "^12.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prisma": "7.6.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.1.0"
  }
}
